# ClawdContext OS — Platform Environment
# Copy to .env and fill in your API keys:
#   cp .env.example .env
#
# LLM Provider Configuration (used by OpenClaw agent runtime)
# Supported: mock | deepseek | openai | anthropic | ollama
# "mock" requires no API key — good for testing the security stack.

LLM_PROVIDER=mock
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
