{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Total Token Spend (Today)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(ccos_tokens_consumed_total[24h]))", "legendFormat": "Tokens", "refId": "A" }
      ],
      "options": { "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Estimated Cost (Today)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(ccos_estimated_cost_usd[24h]))", "legendFormat": "Cost", "refId": "A" }
      ],
      "options": { "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } }
    },
    {
      "title": "Tokens by Skill",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (skill) (increase(ccos_tokens_consumed_total[24h]))", "legendFormat": "{{skill}}", "refId": "A" }
      ],
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "title": "Tokens by Agent Role",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (agent) (increase(ccos_tokens_consumed_total[24h]))", "legendFormat": "{{agent}}", "refId": "A" }
      ],
      "options": { "pieType": "donut" }
    },
    {
      "title": "Token Consumption Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(ccos_tokens_consumed_total[5m]) * 60", "legendFormat": "{{skill}} (tokens/min)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "stacking": { "mode": "normal" }, "fillOpacity": 30, "lineWidth": 1 },
          "unit": "short"
        }
      }
    },
    {
      "title": "Cost Projection (30 days)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(ccos_estimated_cost_usd[24h])) * 30", "legendFormat": "30-day projection", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 2,
          "thresholds": {
            "steps": [
              { "color": "#00E676", "value": null },
              { "color": "#FFB300", "value": 50 },
              { "color": "#FF3D71", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "title": "Budget Utilization",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(ccos_tokens_consumed_total[24h])) / sum(ccos_token_budget) * 100", "legendFormat": "Budget Used", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "#00E676", "value": null },
              { "color": "#FFB300", "value": 70 },
              { "color": "#FF3D71", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "Rate Limit Headroom",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "1 - (rate(ccos_skill_requests_total[1m]) / ccos_skill_rate_limit)", "legendFormat": "{{skill}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1, "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "#FF3D71", "value": null },
              { "color": "#FFB300", "value": 0.2 },
              { "color": "#00E676", "value": 0.5 }
            ]
          }
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["clawdcontext", "cost", "tokens"],
  "time": { "from": "now-24h", "to": "now" },
  "title": "ClawdContext OS — Cost Attribution",
  "uid": "ccos-cost",
  "version": 1
}
